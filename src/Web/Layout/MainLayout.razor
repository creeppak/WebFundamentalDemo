@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthStateProvider
@inject AppAuthenticationStateProvider AppAuthStateProvider
@inject AuthClient AuthClient
@inject NavigationManager Navigation
@implements IDisposable
<MudThemeProvider @ref="_mudThemeProvider" @bind-IsDarkMode="_isDarkMode" Theme="_theme"/>
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Default">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <img src="header-logo.svg" alt="VST" style="height:38px;margin-left:12px;" />
        <MudSpacer />
        <MudTooltip Text="@(_isDarkMode ? "Light mode" : "Dark mode")">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" OnClick="@(() => _isDarkMode = !_isDarkMode)" />
        </MudTooltip>
        <AuthorizeView>
            <Authorized>
                <MudTooltip Text="Log out">
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                                   OnClick="LogoutAsync" />
                </MudTooltip>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Responsive" ClipMode="DrawerClipMode.Always" Elevation="1">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = AppTheme.Default;

    private bool _isDarkMode = true;
    private bool _drawerOpen;
    private MudThemeProvider? _mudThemeProvider;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _drawerOpen = state.User.Identity?.IsAuthenticated == true;
        AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await _mudThemeProvider!.GetSystemDarkModeAsync();
            StateHasChanged();
        }
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        var state = await task;
        _drawerOpen = state.User.Identity?.IsAuthenticated == true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LogoutAsync()
    {
        await AuthClient.LogoutAsync();
        AppAuthStateProvider.NotifyLogout();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}
